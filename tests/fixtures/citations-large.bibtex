notes = {PMCID: PMC10010675},
doi = {10.21785/icad2022.027}
}
@InProceedings{AltText2022McCall,
title = {Rethinking Alt Text to Improve Its Effectiveness},
author = {Karen McCall and Beverly Chagnon},
year = {2022},
organization = {{ICCHP-AAATE}},
booktitle = {18th International Conference, ICCHP-AAATE 2022},
publisher = {Springer},
abstract = {Traditional Alt Text on a simple graphic can be an effective way to describe the graphic, but Alt Text often fails when used on complex diagrams, maps, infographics and charts. One key reason that might cause the limitations is that Alt Text is only an attribute on an <img> or <Figure> tag, rather than a full, standardized tag that contains semantic information. This paper identifies barriers created by Alt Text as an attribute on tags in HTML, PDF, and EPUB and explores the need to develop better, innovative solutions that can provide more accessible and usable information for those who use adaptive technologies to understand the communication represented by complex graphics.},
categories = {Alt-Text, Screen Reader, Blind, Graphic, Map, Web, Text},
typeof = {Journal Article},
annotation = {This paper reviewed the existing guidelines for alt-text and concluded there was no agreement or rigorous methodology behind the alt-text convention. Most alt text recommendations say to have alt-text be less than 140 characters or a few sentences. The blind individuals interviewed here describe how the alt-text is often not useful, especially for obtaining any detailed information. They also provide recommendations for future alt-text, including adding audio to emphasize the alt-text. The authors describe what low vision users need to view graphics.},
url={https://link.springer.com/chapter/10.1007/978-3-031-08645-8_4}
}
