@inproceedings{lee2022imageexplorer,
title = {ImageExplorer: Multi-Layered Touch Exploration to Encourage Skepticism Towards Imperfect AI-Generated Image Captions},
author = {Lee, Jaewook and Herskovitz, Jaylin and Peng, Yi-Hao and Guo, Anhong},
booktitle = {CHI Conference on Human Factors in Computing Systems},
pages = {1--15},
year = {2022},
categories = {Images, Graphics, Tactile, Text, Blind, App},
abstract = {Blind users rely on alternative text (alt-text) to understand an image; however, alt-text is often missing. AI-generated captions are a more scalable alternative, but they often miss crucial details or are completely incorrect, which users may still falsely trust. In this work, we sought to determine how additional information could help users better judge the correctness of AI-generated captions. We developed ImageExplorer, a touch-based multi-layered image exploration system that allows users to explore the spatial layout and information hierarchies of images, and compared it with popular text-based (Facebook) and touch-based (Seeing AI) image exploration systems in a study with 12 blind participants. We found that exploration was generally successful in encouraging skepticism towards imperfect captions. Moreover, many participants preferred ImageExplorer for its multi-layered and spatial information presentation, and Facebook for its summary and ease of use. Finally, we identify design improvements for effective and explainable image exploration systems for blind users.},
annotation = {This paper evaluated how to help BVIs identify incorrect automatically generated captions, and identify the exact errors of captions. They compared SeeingAI, Facebook, and their own caption tool. They found users liked the ability to move their finger around the screen and hear what is there with the tool the team built, and the summary provided by Facebook’s tool. Other research has shown that BVIs trust captions that are described with no skepticism, but increase skepticism if words like “maybe a *”. The problem with these is there is no way to tell where the incorrect feature may be. Participants in this study also commented that incorrect grammar makes them feel less confident in the caption. When talking about the different interfaces, one participant stated: “... with touch, you can get a little bit of information about what's where, and make a more accurate mental picture. “. Participants also stated, when comparing text-based vs touchscreen based descriptions: “text cannot provide spatial information such as absolute and relative locations”. Participants also said touchscreen interfaces take longer to use, make it more difficult to find all the objects in the picture, make it difficult to identify empty space, and can be more distracting as focus is given to finding objects, rather than understanding the picture. Participants did like the detailed descriptions, and 9/11 participants found the project team’s system most useful because it had the most detail. 6/11 participants also liked their system (image explorer) had a hierarchy, so the user could identify that the bus had a window. 7/12 participants wanted to combine the text descriptions of facebook and the details of Image Explorer. 8/11 participants co-designed their ideal image explorer that included a text description that could first be used, combined with a touchscreen interface for later, more detailed exploration. Image elements should be positioned in a 3 by 3 grid. Participants also wanted to know the number of objects, and the colors of the objects. The researchers list the kinds of questions they asked, e.g., what else is in the image, other than a bed? And How many dogs are in the image? The methodology for this paper was very good. The only element I disliked was the lack of a demo, or the lack of any way to access their image explorer.},
typeof = {Journal Article},
doi = {10.1145/3491102.3501966}
}
