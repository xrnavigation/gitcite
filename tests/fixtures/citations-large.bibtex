@misc{UnityAccessibility2024,
title = {A look at mobile screen reader support in the Unity Engine},
url = {https://unity.com/blog/engine-platform/mobile-screen-reader-support-in-unity},
year = {2024},
author = {Julia Perdigueiro},
abstract = {In a positive shift toward inclusivity, an increasing number of game developers are prioritizing accessibility as an integral aspect of their creations. Unity is dedicated to providing support to help developers achieve their accessibility goals. As Leah Skerry presented during GAconf USA 2023, Unity has been actively working on mobile screen reader support, marking the first of many accessible runtime features slated to enhance gaming experiences in the coming years.},
categories = {Accessibility, VR, Game, Mobile, Screen Reader, API},
typeof = {Blog Post},
}
