@article{ColorBlindness2021RutgersIT,
title = {Color Blindness},
author = {{Rutgers IT}},
journal = {Digital Accessibility: Resources},
year = {2021},
url = {https://it.rutgers.edu/digital-accessibility/knowledgebase/color-blindness/},
abstract = {When designing content that’s intended to be accessible by all users, one important aspect of that is designing with enough color contrast to be accessible by people with color blindness. Color blindness, or color vision deficiency, is a spectrum of experience in which individuals have a reduced ability to distinguish between different colors or shades of colors. This is often hereditary but can also occur naturally as part of the aging process, or from trauma or medication. In terms of prevalence, color blindness occurs in 1 in 12 men (8%) and 1 in 200 women (0.5%) worldwide.},
typeof = {Blog Post},
categories = {Colorblind, Accessibility}
}
