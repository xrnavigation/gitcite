@inproceedings{costanza-chock_design_2018,
title = {Design Justice: towards an intersectional feminist framework for design theory and practice},
url = {https://dl.designresearchsociety.org/drs-conference-papers/drs2018/researchpapers/38},
language = {en},
urldate = {2021-11-16},
author = {Sasha Costanza-Chock},
month = jun,
year = {2018},
categories = {design, intersectionality, read, design justice, intersectional feminism, matrix of domination, Quals},
abstract = {@costanza-chock_design_2018 proposes to define Design Justice as: a theory, practice, and social movement around the design of systems and objects that asks the questions: Who designs, what kinds of impacts does the design perpetuate, how does the design challenge the matrix of domination, what is beneficial or could be/is harmful about the design, and how does the design incorporate community knowledge or design practices? The Design Justice principles are: 1) Everyone can design and is an expert in their own experience; 2) Design knowledge and tools need to be shared with the communities impacted by the design process; 3) The goal of a design is to be sustainable, community lead, and community controlled (not controlled by the designer); 4) Designs should foster greater social and environmental connections without being exploitative; 5) Before attempting to implement or create new designs, designers need to examine what is already successful in the community; and 6) Designers should show respect and appreciation for local, indigenous, and traditional customs and knowledge. Considering the intersectionality of race, gender, and other disadvantaged characteristics is critical when creating inclusive designs (only accounting for one characteristic e.g., gender, is still exclusionary). The Matrix Of Domination describes an intersectional mode of analysis which emphasizes how power, oppression, resistance, privilege, penalties, benefits, and harms are systematically positively and negatively distributed to every individual based on race, class, gender, and other characteristics of oppression. Design Justice looks at questions of equity among designers, beneficiaries, values, scope, sites and site accessibility, ownership, accountability, political economy, and discourse. Equity among designers: Design justice recognizes the universality of design as a human activity and emphasizes the contributions of marginalized people to design history that have been erased rather than focusing on traditional professional design work that is often highly rewarded and dominated by white, cisgender, able bodied men, as a result of structural inequality, unequal access to education, and other factors [@costanza2020design2]. To increase the capacities of marginalized groups, community organizations e.g., Black Girls Code, Code2040, Lesbians Who Tech, and Trans*H4CK, are working to build the design and development skills of women, POC, and LGBTQ folks, and initiatives are focusing on creating design that takes into account the privileges of the assumed “default” user. Accountability: Design justice requires that the people most affected by a design issue are included and participate in the process, as their knowledge and experience is essential for successful outcomes as exemplified in the participatory design methodology that is focused on democratizing and equalizing the design process among stakeholders to create effective solutions, and the feminist HCI principles of pluralism, participation, and embodiment [@simonsen_routledge_2012; @bardzell_feminist_2010]. Accountability is also core to the disability justice movement and is epitomized in the phrase “Nothing About Us, Without Us”, that emphasizes the need for community members to lead and own digital design processes and products to help insure workable solutions that will be adopted [@charlton1998NothingAboutUsWithoutUs]. Values: Design justice considers the values encoded in the affordances of designed objects and processes, as well as the values of those excluded from the design process, to create liberatory, and anti-oppressive tools and systems e.g., Facebook showed their exclusionary values when they only allowed European names on Facebook. Focusing on values helps designers pay attention to the power dynamics that shape design and the values encoded in objects and processes, while recognizing there will always be conflict among marginalized groups. Design justice is a framework that encourages a shift from “deficit to asset based approaches to design scoping”, formal inclusion of community members in design processes, platform cooperativism where communities participate in creating empowering solutions e.g., @irani_turkopticon_2013, and value-based projects e.g., intentionally inclusive hacker and makerspaces. There are organizations, networks and events that focus on implementation of design justice principles, and the Design Justice Network is growing rapidly, although rubrics and toolkits still need to be developed.},
annotation = {My work primarily follows the design justice principles, as sustainable inclusion is my focus: 1) Everyone can design and is an expert in their own experience: Through holding co-designs as seen in @BiggsRemoteCoDesignInTheDigitalAge2022 and @biggs2019MRP, I focus on what the community of blind individuals want in their solutions, and I keep them involved throughout the process as seen in @biggsTothStockmanCoughlanWalker2022Evaluation. Our design process focuses on utopics, where we take the “ideal navigational solution” envisioned by blind individuals during the participatory design in @biggs2019MRP, and work to achieve that vision using the latest technology [@costanza2020directions]. I pay blind designers and developers with intersectional diversity traits to lead the development process, as paying diverse blind individuals is a huge factor in ending inequalities [@costanza2020design2]. I also work to systematically include intersectional diversity e.g., deafblind, low income blind, or autistic blind individuals as co-designers. 2) Design knowledge and tools need to be shared with communities: Although I publish the design tools and techniques I use [@BiggsRemoteCoDesignInTheDigitalAge2022], mentor other blind researchers and developers, and share in many online communities of blind individuals, I need to do more to create usable design tools that can allow blind users to get professional level jobs. 3) The goal of a design is to be sustainable, community lead, and community controlled: I have started a company to commercialize the solution I am building so it can make enough money to keep it alive and solving the needs of the community, and almost everyone working at the company is part of the blindness community with a passion for building blindness focused assistive technology [@XRNavigation2022]. It is my goal to create an inclusive executive team and share equity with those in the company so intellectual property is kept within the community [@costanza2020design2]. The vision of the company is that every geographic map on the web is inclusive. To achieve this vision, the company will eventually need to integrate with all the major digital map providers e.g., @ArcGISPro2022, @GoogleMaps2021, @Mapbox2020, and @MicrosoftPowerBI2022, and we have started with Mapbox. 4) Designs should foster greater social and environmental connections without being exploitative: The digital cross-sensory mapping tool I am designing aims to allow non-developer blind individuals to participate in the geographic information communities e.g., @OpenStreetMap2020, to advocate for geographic data they need. This mapping tool also allows blind individuals to view geo-referenced climate and other environmental geographic representations for the first time, so they can be fully part of the scientific and activist communities focused on monitoring and remediating climate change. 5) Before attempting to implement or create new designs, designers need to examine what is already successful in the community: Before holding participatory designs, I investigated how the blindness community already represented digital geographic information in other contexts, in particular audio games (games that can be played completely in audio that are often made by and for blind individuals) [@biggsyusimcoppin2018audiogame]. I then used these audio game conventions in my mapping tool, and continue to make design choices based on what audio games already do [@BiggsCoughlanCoppin2019design]. 6) Designers should show respect and appreciation for local, indigenous, and traditional customs and knowledge: I participate, observe conventions, and seek feedback from the audio game community to inform my designs [@audiogames.net2018], employ blind developers who have faced unequitable access to geographic information, and seek knowledge from holding co-designs and performing rose, bud, thorn evaluations with blind participants about possible interfaces [@biggs2019MRP; @RoseBudThornGoogle2022; @BiggsRemoteCoDesignInTheDigitalAge2022; @biggsTothStockmanCoughlanWalker2022Evaluation]. It is very important that my work is built from the ground up to be something blind individuals need, will use, and can be sustained and continuously developed to meet the evolving needs of the community. Past non-visual digital mapping projects e.g., @ZhaoPlaisantShneidermanLazar2008, and @loeliger2014wayfinding, were made open source and posted for anyone to contribute to. The problem is there are very few blind individuals with the knowledge and resources to contribute to these projects, and the lead developers left the project to focus on other things. The result is that digital geographic information is still completely inaccessible to blind individuals outside of these outdated and discontinued projects.},
typeof = {Journal Article},
doi = {10.21606/drs.2018.679}
}
@inproceedings{olmsted2010think,
title = {Think-aloud protocols: a comparison of three think-aloud protocols for use in testing data-dissemination web sites for usability},
author = {Olmsted-Hawala, Erica L and Murphy, Elizabeth D and Hawala, Sam and Ashenfelter, Kathleen T},
booktitle = {Proceedings of the SIGCHI conference on human factors in computing systems},
pages = {2381--2390},
year = {2010},
abstract = {We describe an empirical, between-subjects study on the use of think-aloud protocols in usability testing of a federal data-dissemination Web site. This double-blind study used three different types of think-aloud protocols: a traditional protocol, a speech-communication protocol, and a coaching protocol. A silent condition served as the control. Eighty participants were recruited and randomly pre-assigned to one of four conditions. Accuracy and efficiency measures were collected, and participants rated their subjective satisfaction with the site. Results show that accuracy is significantly higher in the coaching condition than in the other conditions. The traditional protocol and the speech-communication protocol are not statistically different from each other with regard to accuracy. Participants in the coaching condition are more satisfied with the Web site than participants in the traditional or speech-communication condition. In addition, there are no significant differences with respect to efficiency (time-on-task). This paper concludes with recommendations for usability practitioners.},
url = {https://dl.acm.org/doi/abs/10.1145/1753326.1753685},
categories = {Method, Qualitative, Study},
typeof = {Journal Article},
doi = {10.5040/9798400613739.0270}
}
@article{fosberg1991blind,
title = {Blind Entrepreneurship: An Analysis of the Randolph-Sheppard Program in the State of Louisiana},
author = {Fosberg, Barry and Lacho, Kenneth J},
journal = {Journal of Business and Entrepreneurship},
volume = {3},
number = {1},
pages = {23},
year = {1991},
publisher = {Association for Small Business and Entrepreneurship},
abstract = {Recent legislation and efforts by the federal, state, and private sectors have focused on providing employment opportunities for the disabled. The federal Randolph-Sheppard Act of 1936 provides self-employment opportunities for the blind by giving them priority in establishing businesses on federal or state property. This study examines the implementation of the Louisiana Randolph-Sheppard program. Problems in participant selection, support, training, and new site locations were identified. Otherwise the state is implementing its federal mandate. Opportunities for research into the Louisiana Randolph-Sheppard program as well as into blind entrepreneurship are presented.},
url = {https://www.proquest.com/docview/214237037?pq-origsite = gscholar&fromopenview = true},
categories = {Blind, Business, Entrepreneur, Comercial, Owner},
typeof = {Journal Article}
}
@unpublished{Biggs2023NonVerbalVRSocialInteractions,
title = {Creating Non-Visual Non-Verbal Social Interactions in Virtual Reality},
author = {Brandon Biggs and Steve Murgaski and Hannah Agbaroji and Rachel Lowy and Peter Coppin and Bruce Walker},
year = {2023},
abstract = {Although virtual reality was originally conceived of as a multi-sensory experience, most developers of the technology have focused on its visual aspects to the detriment of other senses such as hearing. This paper presents design patterns to make virtual reality fully accessible to non-visual users, including totally blind users. Non-visual virtual reality has been present in the blindness audio game community since the early 2000’s, but the conventions from these interfaces have never been described to a sighted audience. This paper presents non-visual design patterns created by five of the top English speaking audio game developers through a three round delphi method, encompassing 29 non-verbal social interactions grouped into 12 categories in VR including movement, emotes, and self-expression. This paper will be useful to developers of VR experiences who wish to represent more information to their users through audible cues.},
categories = {Blind, Delphi, Mine, VR, Auditory, Text, Social, Interaction},
typeof = {Journal Article},
}
@article{jain2023want,
title = {" I Want to Figure Things Out": Supporting Exploration in Navigation for People with Visual Impairments},
author = {Jain, Gaurav and Teng, Yuanyang and Cho, Dong Heon and Xing, Yunhao and Aziz, Maryam and Smith, Brian A},
journal = {Proceedings of the ACM on Human-Computer Interaction},
volume = {7},
number = {CSCW1},
pages = {1--28},
year = {2023},
publisher = {ACM New York, NY, USA},
url = {https://dl.acm.org/doi/10.1145/3579496},
categories = {Blind, Navigation, Wayplanning, Map},
abstract = {Navigation assistance systems (NASs) aim to help visually impaired people (VIPs) navigate unfamiliar environments. Most of today's NASs support VIPs via turn-by-turn navigation, but a growing body of work highlights the importance of exploration as well. It is unclear, however, how NASs should be designed to help VIPs explore unfamiliar environments. In this paper, we perform a qualitative study to understand VIPs' information needs and challenges with respect to exploring unfamiliar environments to inform the design of NASs that support exploration. Our findings reveal the types of spatial information that VIPs need as well as factors that affect VIPs' information preferences. We also discover specific challenges that VIPs face that future NASs can address, such as orientation and mobility education and collaborating effectively with others. We present design implications for NASs that support exploration, and we identify specific research opportunities and discuss open socio-technical challenges for making such NASs possible. We conclude by reflecting on our study procedure to inform future approaches in research on ethical considerations that may be adopted while interacting with the broader VIP community.},
typeof = {Journal Article},
doi = {10.1145/3579496}
}
@inproceedings{banovic2013uncovering,
title = {Uncovering information needs for independent spatial learning for users who are visually impaired},
author = {Banovic, Nikola and Franz, Rachel L and Truong, Khai N and Mankoff, Jennifer and Dey, Anind K},
booktitle = {Proceedings of the 15th international ACM SIGACCESS conference on computers and accessibility},
pages = {1--8},
year = {2013},
abstract = {Sighted individuals often develop significant knowledge about their environment through what they can visually observe. In contrast, individuals who are visually impaired mostly acquire such knowledge about their environment through information that is explicitly related to them. This paper examines the practices that visually impaired individuals use to learn about their environments and the associated challenges. In the first of our two studies, we uncover four types of information needed to master and navigate the environment. We detail how individuals' context impacts their ability to learn this information, and outline requirements for independent spatial learning. In a second study, we explore how individuals learn about places and activities in their environment. Our findings show that users not only learn information to satisfy their immediate needs, but also to enable future opportunities -- something existing technologies do not fully support. From these findings, we discuss future research and design opportunities to assist the visually impaired in independent spatial learning.},
categories = {Blind, Navigation, Wayplanning},
typeof = {Journal Article},
url = {https://dl.acm.org/doi/abs/10.1145/2513383.2513445},
doi = {10.1145/2513383.2513445}
}
@article{memeo2023blindTactileDevice,
title = {Blind people can actively manipulate virtual objects with a novel tactile device},
author = {Memeo, Mariacarla and Sandini, Giulio and Cocchi, Elena and Brayda, Luca},
journal = {Scientific Reports},
volume = {13},
number = {1},
pages = {22845},
year = {2023},
publisher = {Nature Publishing Group UK London},
annotation = {I think the 1 finger viewer has some promise, but 1) the viewer was not described in this paper very well; 2) The shape manipulations were not described very well; and 3) I am still not sure of the practical application of this device, considering maps normally have hundreds or thousands of features. They have a very good introduction and analysis that I should copy the format of. The paper is well-written, but the contribution to science is poor.},
categories = {Blind, Tactile, Map, Study, Device},
abstract = {Frequently in rehabilitation, visually impaired persons are passive agents of exercises with fixed environmental constraints. In fact, a printed tactile map, i.e. a particular picture with a specific spatial arrangement, can usually not be edited. Interaction with map content, instead, facilitates the learning of spatial skills because it exploits mental imagery, manipulation and strategic planning simultaneously. However, it has rarely been applied to maps, mainly because of technological limitations. This study aims to understand if visually impaired people can autonomously build objects that are completely virtual. Specifically, we investigated if a group of twelve blind persons, with a wide age range, could exploit mental imagery to interact with virtual content and actively manipulate it by means of a haptic device. The device is mouse-shaped and designed to jointly perceive, with one finger only, local tactile height and inclination cues of arbitrary scalar fields. Spatial information can be mentally constructed by integrating local tactile cues, given by the device, with global proprioceptive cues, given by hand and arm motion. The experiment consisted of a bi-manual task, in which one hand explored some basic virtual objects and the other hand acted on a keyboard to change the position of one object in real-time. The goal was to merge basic objects into more complex objects, like a puzzle. The experiment spanned different resolutions of the tactile information. We measured task accuracy, efficiency, usability and execution time. The average accuracy in solving the puzzle was 90.5%. Importantly, accuracy was linearly predicted by efficiency, measured as the number of moves needed to solve the task. Subjective parameters linked to usability and spatial resolutions did not predict accuracy; gender modulated the execution time, with men being faster than women. Overall, we show that building purely virtual tactile objects is possible in absence of vision and that the process is measurable and achievable in partial autonomy. Introducing virtual tactile graphics in rehabilitation protocols could facilitate the stimulation of mental imagery, a basic element for the ability to orient in space. The behavioural variable introduced in the current study can be calculated after each trial and therefore could be used to automatically measure and tailor protocols to specific user needs. In perspective, our experimental setup can inspire remote rehabilitation scenarios for visually impaired people.},
url = {https://www.nature.com/articles/s41598-023-49507-1},
typeof = {Journal Article},
doi = {10.1038/s41598-023-49507-1}
}
@article{delogu2010non,
title = {Non-visual exploration of geographic maps: does sonification help?},
author = {Delogu, Franco and Palmiero, Massimiliano and Federici, Stefano and Plaisant, Catherine and Zhao, Haixia and Belardinelli, Olivetti},
journal = {Disability and Rehabilitation: Assistive Technology},
volume = {5},
number = {3},
pages = {164--174},
year = {2010},
publisher = {Taylor \& Francis},
abstract = {Purpose. This study aims at evaluating the effectiveness of sonification as a mean to provide access to geo-referenced information to users with visual impairments. Method. Thiry-five participants (10 congenitally blind, 10 with acquired blindness and 15 blindfolded sighted) completed four tasks of progressive difficulty. During each task, participants first explored a sonified map by using either a tablet or a keyboard to move across regions and listened to sounds giving information about the current location. Then the participants were asked to identify, among four tactile maps, the one that crossmodally corresponds to the sonifed map they just explored. Finally, participants answered a self-report questionnaire of understanding and satisfaction. Results. Participants achieved high accuracy in all of the four tactile map discrimination tasks. No significant performance difference was found neither between subjects that used keyboard or tablet, nor between the three groups of blind and sighted participants. Differences between groups and interfaces were found in the usage strategies. High levels of satisfaction and understanding of the tools and tasks emerged from users' reports.},
annotation = {This paper compared an auditory tactile map and sonification map and found no difference between them. Participants had trouble telling shapes apart and counting the features on the map. They were able to tell the shape of the map and identify trends. This paper showed that participants can perform spatial cognition visually, but performing complex tasks is difficult.},
url = {https://www.tandfonline.com/doi/full/10.3109/17483100903100277},
categories = {Blind, Amazing, Auditory, Tactile, Map, Study},
typeof = {Journal Article},
doi = {10.3109/17483100903100277}
}
@article{ottink2022cognitive,
title = {Cognitive map formation supported by auditory, haptic, and multimodal information in persons with blindness},
author = {Ottink, Loes and Buimer, Hendrik and van Raalte, Bram and Doeller, Christian F and van der Geest, Thea M and van Wezel, Richard JA},
journal = {Neuroscience \& Biobehavioral Reviews},
pages = {104797},
year = {2022},
publisher = {Elsevier},
categories = {Digital, Auditory, Tactile, Blind, Map, Amazing, Litrature Review},
annotation = {This paper reviews digital auditory, speech-based, tactile, multimodal, and physical navigation for determining if BVIs can perform spatial cognition and the answer is yes, in all modalities. Tactile and physical navigation seem to be the best, although they have not been compared with audio. One explanation for this is that BVIs are trained in physical navigation and reading tactile maps and have little experience with auditory maps. The paper highlights the significant need for more research around auditory maps. There has been no research around direction estimation. There has also been very little comparison between BVIs and sighted individuals. They split BVIs into early onset (before 3 years old) and late onset blindness (after 3 years old). They split auditory maps into those with verbal feedback and without verbal feedback, but don’t talk about maps that use both (although these are grouped into verbal). There are 17 papers, 11 verbal. They talk about five methods of evaluating spatial knowledge: “Route: walking a route, reproduction of a route by drawing or building; Layout: reproduction of a layout by drawing or building, choosing the correct model out of several incorrect ones, arrange objects into the correct configuration; Locations: location recall, reaching targets in environment, locational judgments about objects in an arrangement; Distance: estimating absolute or relative distances between locations; Direction: pointing task from start location, own location, or other location”.},
abstract = {For efficient navigation, the brain needs to adequately represent the environment in a cognitive map. In this review, we sought to give an overview of literature about cognitive map formation based on non-visual modalities in persons with blindness (PWBs) and sighted persons. The review is focused on the auditory and haptic modalities, including research that combines multiple modalities and real-world navigation. Furthermore, we addressed implications of route and survey representations. Taking together, PWBs as well as sighted persons can build up cognitive maps based on non-visual modalities, although the accuracy sometime somewhat differs between PWBs and sighted persons. We provide some speculations on how to deploy information from different modalities to support cognitive map formation. Furthermore, PWBs and sighted persons seem to be able to construct route as well as survey representations. PWBs can experience difficulties building up a survey representation, but this is not always the case, and research suggests that they can acquire this ability with sufficient spatial information or training. We discuss possible explanations of these inconsistencies.},
url = {https://www.sciencedirect.com/science/article/pii/S014976342200286X},
doi = {10.1016/j.neubiorev.2022.104797}
}
@article{ottink2022cognitiveTactileMaps,
title = {Cognitive map formation through tactile map navigation in visually impaired and sighted persons},
author = {Ottink, Loes and Van Raalte, Bram and Doeller, Christian F and Van der Geest, Thea M and Van Wezel, Richard JA},
journal = {Scientific reports},
volume = {12},
number = {1},
pages = {11567},
year = {2022},
publisher = {Nature Publishing Group UK London},
abstract = {The human brain can form cognitive maps of a spatial environment, which can support wayfinding. In this study, we investigated cognitive map formation of an environment presented in the tactile modality, in visually impaired and sighted persons. In addition, we assessed the acquisition of route and survey knowledge. Ten persons with a visual impairment (PVIs) and ten sighted control participants learned a tactile map of a city-like environment. The map included five marked locations associated with different items. Participants subsequently estimated distances between item pairs, performed a direction pointing task, reproduced routes between items and recalled item locations. In addition, we conducted questionnaires to assess general navigational abilities and the use of route or survey strategies. Overall, participants in both groups performed well on the spatial tasks. Our results did not show differences in performance between PVIs and sighted persons, indicating that both groups formed an equally accurate cognitive map. Furthermore, we found that the groups generally used similar navigational strategies, which correlated with performance on some of the tasks, and acquired similar and accurate route and survey knowledge. We therefore suggest that PVIs are able to employ a route as well as survey strategy if they have the opportunity to access route-like as well as map-like information such as on a tactile map.},
url = {https://www.nature.com/articles/s41598-022-15858-4},
categories = {Blind, Cognition, Spatial, Map, Reproduction, Tactile},
typeof = {Journal Article},
doi = {10.1038/s41598-022-15858-4}
}
@article{ducasse2018accessible,
title = {Accessible interactive maps for visually impaired users},
author = {Ducasse, Julie and Brock, Anke M and Jouffrais, Christophe},
journal = {Mobility of Visually Impaired People: Fundamentals and ICT Assistive Technologies},
pages = {537--584},
year = {2018},
publisher = {Springer},
abstract = {Tactile maps are commonly used to give visually impaired users access to geographical representations. Although those relief maps are efficient tools for acquisition of spatial knowledge, they present several limitations and issues such as the need to read braille. Several research projects have been led during the past three decades in order to improve access to maps using interactive technologies. In this chapter, we present an exhaustive review of interactive map prototypes. We classified existing interactive maps into two categories: Digital Interactive Maps (DIMs) that are displayed on a flat surface such as a screen; and Hybrid Interactive Maps (HIMs) that include both a digital and a physical representation. In each family, we identified several subcategories depending on the technology being used. We compared the categories and subcategories according to cost, availability, and technological limitations, but also in terms of content, comprehension, and interactivity. Then we reviewed a number of studies showing that those maps can support spatial learning for visually impaired users. Finally, we identified new technologies and methods that could improve the accessibility of graphics for visually impaired users in the future.},
annotation = {This paper looks at digital and hybrid interactive tactile maps. The categories they use are: digital maps, Interactive Tactile Maps, Tangible Maps, and Refreshable Tactile Maps. Interactive maps generally show data of limited complexity, are simple, are cognitively demanding, have problems when users explore lines, have problems because users don’t know where they’re exactly pointing at all times, intersections are hard to identify, zooming and panning is extremely confusing for users, it’s difficult to show more than a few features on the map, and no one has investigated filtering, highlighting, annotating, or creating. See the discussion section for an exhaustive list of pros and cons for each display. The conclusion is that interactive raised line maps are the best, although they also have a number of problems, mainly need for printing every update of the map. They also talk about accessible graphics and how charts and maps are somewhat similar, so could possibly use the same interface.},
categories = {Blind, Tactile, Vibratory, Tablet, VAM, Map, Litrature Review, Amazing},
typeof = {Journal Article},
url = {https://link.springer.com/chapter/10.1007/978-3-319-54446-5_17},
doi = {10.1007/978-3-319-54446-5_17}
}
@inproceedings{carroll2013designing,
title = {Designing accessible visualizations: The case of designing a weather map for blind users},
author = {Carroll, Dustin and Chakraborty, Suranjan and Lazar, Jonathan},
booktitle = {Universal Access in Human-Computer Interaction. Design Methods, Tools, and Interaction Techniques for eInclusion: 7th International Conference, UAHCI 2013, Held as Part of HCI International 2013, Las Vegas, NV, USA, July 21-26, 2013, Proceedings, Part I 7},
pages = {436--445},
year = {2013},
organization = {Springer},
abstract = {Major strides have been made to improve the accessibility of text-based documents for blind users, however, visualizations still remain largely inaccessible. The AISP framework represents an attempt to streamline the design process by aligning the information seeking behaviors of a blind user with those of a sighted user utilizing auditory feedback. With the recent popularity of touch-based devices, and the overwhelming success of the talking tactile tablet, we therefore suggest that the AISP framework be extended to include the sense of touch. This research-in-progress paper proposes such an extended design framework, MISD. In addition, the article also presents the preliminary work done in designing an accessible weather map based on our theory-driven design. A discussion and an outline of future work conclude the manuscript.},
typeof = {Journal Article},
categories = {VAM, Tactile, Vibro, Auditory, Map, Thematic, Study, Blind, Touchscreen},
url = {https://link.springer.com/chapter/10.1007/978-3-642-39188-0_47},
doi = {10.1007/978-3-642-39188-0_47}
}
@inproceedings{su2010timbremap,
title = {Timbremap: enabling the visually-impaired to use maps on touch-enabled devices},
author = {Su, Jing and Rosenzweig, Alyssa and Goel, Ashvin and de Lara, Eyal and Truong, Khai N},
booktitle = {Proceedings of the 12th international conference on Human computer interaction with mobile devices and services},
pages = {17--26},
year = {2010},
typeof = {Journal Article},
abstract = {Mapping applications on mobile devices have gained widespread popularity as a means for enhancing user mobility and ability to explore new locations and venues. Visually impaired users currently rely on computer text-to-speech or human-spoken descriptions of maps and indoor spaces. Unfortunately, speech-based descriptions are limited in their ability to succinctly convey complex layouts or spacial positioning. This paper presents Timbremap, a sonification interface enabling visually impaired users to explore complex indoor layouts using off-the-shelf touch-screen mobile devices. This is achieved using audio feedback to guide the user's finger on the device's touch interface to convey geometry. Our user-study evaluation shows Timbremap is effective in conveying non-trivial geometry and enabling visually impaired users to explore indoor layouts.},
categories = {Blind, Auditory, Tactile, Vibratory, Blind, Map, Study, Touchscreen, Mobile},
typeof = {Journal Article},
annotation = {This paper creates a touchscreen map on an iPhone and evaluates it with several small studies of between 1-6 BVIs. They used spearcon hints to tell the user where lines were if they left them. The result was promising, but they only showed less than 20 features on the map.},
url = {https://dl.acm.org/doi/abs/10.1145/1851600.1851606}
}
@inproceedings{walkera2021swan,
title = {SWAN 2.0: Research and Development on a New System for Wearable Audio Navigation},
author = {Walker, Bruce N and Wilson, Jeff},
booktitle = {Proceedings of the WirelessRERC State of the Technology Forum},
year = {2021},
url = {https://wirelessrerc.gatech.edu/sites/default/files/publications/walker_swan2-wirelessrerc-sot2021-proceedings-v16-withalttext.pdf},
categories = {Blind, Auditory, AR, Wayfinding, Navigation, TBTNS, Application},
abstract = {A System for Wearable Audio Navigation (SWAN) has been developed that aids a user in navigation, orientation, and situation awareness. SWAN provides support to persons with temporary or permanent visual impairment. SWAN has undergone many iterations, with the common requirement for mobility via wearable computing platforms, spatialized audio output, and robust position/orientation tracking of the user.},
typeof = {Journal Article},
doi = {10.1109/iswc.2007.4373786}
}
@inproceedings{kvitle2018accessibleColorblind,
title = {Accessible maps for the color vision deficient observers: past and present knowledge and future possibilities},
author = {Kvitle, Anne Kristin},
booktitle = {Proceedings of the ICA},
volume = {1},
pages = {64},
year = {2018},
organization = {Copernicus Publications G{\"o}ttingen, Germany},
abstract = {Color is part of the visual variables in map, serving an aesthetic part and as a guide of attention. Impaired color vision affects the ability to distinguish colors, which makes the task of decoding the map colors difficult. Map reading is reported as a challenging task for these observers, especially when the size of stimuli is small. The aim of this study is to review existing methods for map design for color vision deficient users. A systematic review of research literature and case studies of map design for CVD observers has been conducted in order to give an overview of current knowledge and future research challenges. In addition, relevant research on simulations of CVD and color image enhancement for these observers from other fields of industry is included. The study identified two main approaches: pre-processing by using accessible colors and post-processing by using enhancement methods. Some of the methods may be applied for maps, but requires tailoring of test images according to map types.},
url = {https://ica-proc.copernicus.org/articles/1/64/2018/},
categories = {Colorblind, Map, Visual, Design},
typeof = {Journal Article},
doi = {10.5194/ica-proc-1-64-2018}
}
