@article{swobodzinski2019comprehensive,
title = {A comprehensive examination of electronic wayfinding technology for visually impaired travelers in an urban environment},
author = {Swobodzinski, Martin and Parker, Amy T},
year = {2019},
url = {https://doi.org/10.15760/trec.227},
abstract = {In this project, we distilled an inventory of smartphone-based electronic travel aid technology for the wayfinding of visually impaired travelers in an urban environment based on a thorough review of software marketplaces and the academic literature. Subsequently, we solicited structured input from domain experts and visually impaired individuals on their experiences and evaluations pertaining to personal telecommunication technology for safe and efficient wayfinding. The insights gained from this project are instrumental for the conceptualization and development of integrated route planning and guidance application that address the distinct information needs and expectations of individuals with a vision-related functional impairment. The very objective of our project is to provide pathways for improving the quality of life of people who experience disproportionate impediments to their mobility through inclusive pedestrian navigation in an urban environment.},
categories = {Amazing, Blind, Navigation, Wayfinding, Turn-By-Turn},
typeof = {Government Report},
annotation = {This paper surveyed O&Ms, deafblind and blind travelers on the apps they used and what they wanted in an app. Their app list is very comprehensive. They don't talk about pre-trip planning though.},
doi = {10.15760/trec.227}
}
@misc{AFB2022TheJourneyForward,
title = {The Journey Forward: Recovery from the COVID-19 Pandemic},
institution = {American Foundation for the Blind},
year = {2022},
url = {https://www.afb.org/research-and-initiatives/covid-19-research/journey-forward/introduction},
categories = {COVID, Blind, Study, Navigation, Technology, Transpertation, Accessibility},
abstract = {In July and August of 2021, the Journey Forward survey was conducted to capture the experiences of adults with low vision or blindness during the COVID-19 pandemic. The findings supplement the results of the 2020 Flatten Inaccessibility1 survey that was administered early in the pandemic, in April 2020. Different questions were asked in the two surveys, with Journey Forward focusing on issues that had evolved or had been introduced since the earlier survey, such as access to COVID-19 testing and vaccines, healthcare, food and supplies, as well as access to voting in the 2020 elections.},
typeof = {Report},
}
@misc{AppleMapsPatent2012,
title = {Touch-based exploration of maps for screen reader users},
author = {Christopher B. Fleizach and Reginald D. Hudson and Michael M. Pedersen and Samuel C. White and Joel Lopes Da Silva},
institution = {Apple Inc},
year = {2012},
notes = {Number: US10330490B2},
url = {https://patents.google.com/patent/US10330490B2/en},
abstract = {An electronic device can provide an interactive map with non-visual output, thereby making the map accessible to visually impaired users. The map can be based on a starting location defined based on a current location of the electronic device or on a location entered by the user. Nearby paths, nearby points of interest, or directions from the starting location to an ending location can be identified via audio output. Users can touch a screen of the electronic device in order to virtually explore a neighborhood. A user can be alerted when he is moving along or straying from a path, approaching an intersection or point of interest, or changing terrains. Thus, the user can familiarize himself with city-level spatial relationships without needing to physically explore unfamiliar surroundings.},
type = {Patent},
categories = {Auditory, Tactile, Blind, Interface, Touchscreen, Map},
}
@article{bell2019access,
title = {Access to math and science content for youth who are blind or visually impaired},
author = {Bell, Edward C and Silverman, Arielle M},
year = {2019},
journal = {The Journal of Blindness Innovation and Research},
volume = {9},
number = {1},
url = {https://nfb.org/images/nfb/publications/jbir/jbir19/jbir090101.html},
abstract = {Youth between the ages of 10-18 were surveyed during the Fall of 2016 related to their experiences of accessing math and science-related content in schools. Youth shared the most common methods currently used to access these materials in class and the various combinations of low-tech and high-tech solutions at their disposal, including print, braille, and various means for performing calculations. While the vast majority of youth reported having a Teacher of the Visually Impaired or aid who helped them with math and science work, 82% reported having trouble accessing information that teachers put on the board most of the time or occasionally. Youth were overall positive about their desire to learn math and science in school. However, they also reported that factors such as receiving their materials later than classmates, not having visual concepts adequately explained, and classroom teacher's general lack of comfort while working with these youth were all cited as deterrents to learning.},
categories = {Blind, STEM, Students, Accessibility, Math, Graphics, Tactile},
typeof = {Journal Article},
annotation = {This paper is fantastic at showing inequalities with access to content, and the negative impact and feelings this has on BVI students. 49 students were surveyed, and 72% said access problems impact their ability to learn. 85% said they received materials late, and 85% said they have trouble accessing content on the board. The problem with this evaluation is that maps and geography were not explicitly mentioned.},
doi = {10.5241/9-152}
}
@inproceedings{troncoso2020aiguide,
title = {AIGuide: An Augmented Reality Hand Guidance Application for People with Visual Impairments},
author = {Troncoso Aldas, Nelson Daniel and Lee, Sooyeon and Lee, Chonghan and Rosson, Mary Beth and Carroll, John M and Narayanan, Vijaykrishnan},
booktitle = {The 22nd International ACM SIGACCESS Conference on Computers and Accessibility},
pages = {1--13},
year = {2020},
url = {https://dl.acm.org/doi/abs/10.1145/3373625.3417028},
annotation = {This study investigates the usage of an object recognition and user guidance system to that object. They evaluated on 10 blind participants. The problem with this study is that they invent their own method of guiding users to an object. They also had limited accuracy, it may be limited for 20cm, especially when using a phone. They didn't go enough detail about the technical details, around model creation. There needs to be a comparison of guidance methods, either using what they describe, or what we did in CamIO. They also don't evaluate the system as a hole. This paper focuses a lot on the platform, but in reality, their paper focused on the guidance system, and less on the other aspects of the process. They define the selection, localization, guidance, and conformation phases of object location. Participants disliked the conformation phase and didn't find it useful. The selection, localization, and guidance phases seem to all require their own evaluation, or report. Instead, this paper focused on guidance. They ran a remote study where they mailed phone and objects to participants.},
abstract = {Locating and grasping objects is a critical task in people’s daily lives. For people with visual impairments, this task can be a daily struggle. The support of augmented reality frameworks in smartphones has the potential to overcome the limitations of current object detection applications designed for people with visual impairments. We present AIGuide, a self-contained ofine smartphone application that leverages augmented reality technology to help users locate and pick up objects around them. We conducted a user study to validate its efectiveness at providing guidance, compare it to other assistive technology form factors, evaluate the use of multimodal feedback, and provide feedback about the overall experience. Our results show that AIGuide is a promising technology to help people with visual impairments locate and acquire objects in their daily routine.},
categories = {Computer Vision, Auditory, Tactile, Blind, Accessibility, Study},
typeof = {Journal Article},
doi = {10.1145/3373625.3417028}
}
