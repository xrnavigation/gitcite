pages = {27245},
doi = {10.1038/s41598-025-08117-9},
pmid = {40715121},
pmcid = {PMC12297645},
issn = {2045-2322},
publisher = {Nature Publishing Group},
url = {https://doi.org/10.1038/s41598-025-08117-9}
}
@inproceedings{clepper2025would,
title={" What Would I Want to Make? Probably Everything": Practices and Speculations of Blind and Low Vision Tactile Graphics Creators},
author={Clepper, Gina and McDonnell, Emma J and Findlater, Leah and Peek, Nadya},
booktitle={Proceedings of the 2025 CHI Conference on Human Factors in Computing Systems},
pages={1--16},
year={2025},
abstract={Tactile graphics communicate images and spatial information to blind and low vision (BLV) audiences via touch. However, designing and producing tactile graphics is laborious and often inaccessible to BLV people themselves. We interviewed 14 BLV adults with experience both using and creating tactile graphics to understand their current and desired practices. We found that tactile graphics are intensely valued by many, but that access to and fluency with tactile graphics are compounding challenges. To produce tactile graphics, BLV makers constantly navigate tradeoffs between accessible, lowfidelity craft materials and less accessible, high-fidelity equipment.},
categories={Tactile, Graphic, Map, Create, Blind, Qualitative, Design},
typeof={Journal Article},
url={https://ej-mcdonnell.github.io/tactileGraphics.pdf}
}
@article{manzoni2025mapio,
title={MapIO: a Gestural and Conversational Interface for Tactile Maps},
author={Manzoni, Matteo and Mascetti, Sergio and Ahmetovic, Dragan and Crabb, Ryan and Coughlan, James M},
journal={IEEE Access},
year={2025},
publisher={IEEE},
abstract={For individuals who are blind or have low vision, tactile maps provide essential spatial information but are limited in the amount of data they can convey. Digitally augmented tactile maps enhance these capabilities with audio feedback, thereby combining the tactile feedback provided by the map with an audio description of the touched elements. In this context, we explore an embodied interaction paradigm to augment tactile maps with conversational interaction based on Large Language Models, thus enabling users to obtain answers to arbitrary questions regarding the map. We analyze the types of questions the users are interested in asking, engineer the Large Language Model’s prompt to provide reliable answers, and study the resulting system with a set of 10 participants, evaluating how the users interact with the system, its usability, and user experience.},
url={https://ieeexplore.ieee.org/abstract/document/10981719},
doi={10.1109/ACCESS.2025.3566286},
categories={Blind, Interactive, Map, Tactile, Navigation, TMAP, LLM, AI, Blind},
typeof={Journal Article}
}
@misc{Monarch2025Tactile,
title={Monarch},
abstract={On Monarch, educational resources are readily available, cutting down on the need for specialized materials and additional classroom expenses. Time that would have been spent adapting lesson plans and creating materials is dramatically decreased, allowing educators to focus on what truly matters – teaching. With over 2000 graphics in the TGIL and connection to a variety of online libraries, students can take control of their learning journey, exploring concepts and ideas with newfound freedom.},
author={{American Printing House for the Blind}},
note={Accessed: May 29, 2025},
url={https://www.aph.org/product/monarch/},
categories={Tactile, Display, Digital, Braille, Device, Blind},
typeof={Product}
}
