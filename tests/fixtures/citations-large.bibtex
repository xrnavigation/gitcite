abstract = {Downloadable data files containing annual cumulative enrollment data by race/ethnicity, gender, and program subgroup, including special education.},
annotation = {Sped is SD in column G},
}
@article{munro2017development,
title = {Development and initial validation of the'O and M VISSIT'for orientation and mobility specialists to determine service intensity},
author = {Munro, Heather R and Darst, Shannon and Pogrund, Rona L},
journal = {International Journal of Orientation and Mobility},
volume = {9},
number = {1},
pages = {11--21},
year = {2017},
abstract = {The purpose of this study was to provide initial validation of the Orientation and Mobility Visual Impairment Scale of Service Intensity of Texas (O and M VISSIT) intended for use by orientation and mobility (O and M) specialists to determine a recommended type and amount of O and M services for students on their caseloads based on each student's identified needs. The validity and reliability of the scale were calculated using a mixed-methods survey research design, with purposive expert sampling. The O and M VISSIT was found to be significantly valid in social and content validity and moderately valid in consequential validity. The O and M VISSIT is a moderately reliable tool to assist determine the appropriate type and amount of O and M services for all students on the O and M specialist's caseload.},
categories = {O&M, Mobility, Teacher, IEP, Service, Sped, Method, Study},
doi = {10.21307/ijom-2018-003}
}
@inproceedings{ruvolo2021considering,
title = {Considering Spatial Cognition of Blind Travelers in Utilizing Augmented Reality for Navigation},
author = {Ruvolo, Paul},
booktitle = {2021 IEEE International Conference on Pervasive Computing and Communications Workshops and other Affiliated Events (PerCom Workshops)},
pages = {99--104},
year = {2021},
organization = {IEEE},
abstract = {Recent work has shown that smartphone-based augmented reality technology (AR) has the potential to be leveraged by people who are blind or visually impaired (BVI) for indoor navigation. The fact that this technology is low-cost, widely available, and portable further amplifies the opportunities for impact. However, when utilizing AR for navigation, there are many possible ways to communicate the spatial information encoded in the AR world to the user, and the choice of how this information is presented to the user may have profound effects on the usability of this information for navigation. In this paper we describe frameworks from the field of spatial cognition, discuss important results in spatial cognition for folks who are BVI, and use these results and frameworks to lay out possible user interface paradigms for AR-based navigation technology for people who are BVI. We also present findings from a route dataset collected from an AR-based navigation application that support the urgency of considering spatial cognition when developing AR technology for people who are BVI.},
annotation = {This paper discusses the theory behind different coordinate systems in AR. These would be how the directions are presented to the user. There is egocentric, allocentric, local, and global. Soundscape from Microsoft uses local, Audiom uses more global. I wish they would have given more citations on where they came up with this local and global system. They describe the need for more tools to help BVIs learn global and allocentric frames of reference.},
categories = {AR, Blind, Navigation, Wayfinding, Spatial},
typeof = {Journal Article},
doi = {10.1109/percomworkshops51409.2021.9430997}
}
