@misc{DisabilityStatisticsWHO,
title = {Disability},
author = {{World Health Organization}},
year = {2023},
url = {https://www.who.int/news-room/fact-sheets/detail/disability-and-health#:~:text = It%20results%20from%20the%20interaction,experience%20a%20significant%20disability%20today.},
abstract = {An estimated 1.3 billion people experience significant disability. This represents 16% of the world’s population, or 1 in 6 of us. Some persons with disabilities die up to 20 years earlier than those without disabilities. Persons with disabilities have twice the risk of developing conditions such as depression, asthma, diabetes, stroke, obesity or poor oral health. Persons with disabilities face many health inequities. Persons with disabilities find inaccessible and unaffordable transportation 15 times more difficult than for those without disabilities. Health inequities arise from unfair conditions faced by persons with disabilities, including stigma, discrimination, poverty, exclusion from education and employment, and barriers faced in the health system itself.},
note = {Accessed August 31, 2024},
typeof = {Report},
categories = {Disability, Disabled, Statistics, Report},
}
@book{kuhn_structure_2012_2,
address = {Chicago ; London},
edition = {Fourth edition},
title = {The structure of scientific revolutions},
chapter = {2},
isbn = {978-0-226-45811-3 978-0-226-45812-0},
publisher = {The University of Chicago Press},
author = {Kuhn, Thomas S.},
collaborator = {Hacking, Ian},
year = {2012},
categories = {Philosophy, Science, History, Quals},
abstract = {@kuhn_structure_2012_2 describes how science is now founded on the idea of a "shared paradigm" that students learn as they go through school. He points out that this was not the case during the time of Newton. He said there were numerous theories on the properties of light, and electricity, for example, that were only loosely related. Books were written for individuals outside the current theory more than to other members of the current theory. In electricity, all the competing theories were based off of the mcchanico-corpuscular philosophy (that electricity was particles) and researchers performed experiments and observations that contributed to the body of knowledge until Franklin came up with a theory that unified most everyone, and those who didn't agree were relegated to philosophical discussions. Paradigms are both innovative enough to attract individuals away from the primary scientific practice, and raises enough questions that many other scientists can continue work in a similar vain. The paradigms and theories don’t need to explain all elements, e.g., some electricity theories thought it was a fluid or particle, and had trouble explaining attraction and repulsive effects. This set of theories before the community agrees is very common, and the reason why there are so many theories is because it’s difficult to know what is most important about a Phenomena. Having a unified paradigm has several advantages, including not needing to justify the basics in writing, it is taught in school, there are professional organizations, researchers can write articles instead of books, phenomena can be investigated and excruciating detail that wouldn’t otherwise be investigated, and journals are created around the theory. The cons are: the competing paradigms and fields are completely dismissed, and phenomena outside the paradigm are often missed. Research in a paradigm falls into three vague areas: 1) determination of significant fact: Exploring to increase accuracy and scope the set of facts the paradigm deems important e.g., electrical conductivity and contact potential; 2) matching of facts with theory; and most importantly 3) articulation of theory: Performing experiments or creating theories to further explain the paradigm by creating laws or universal constants, guessing laws before technology can perform experiments, and exploring ambiguities when the paradigm is applied outside the original domain where another accepted paradigm may have a conflict.},
typeof = {Book},
annotation = {"These transformations of the paradigms of physical optics are scientific revolutions, and the successive transition from one paradigm to another via revolution is the usual developmental pattern of mature science. It is not, however, the pattern characteristic of the period before Newton's work, and that is the contrast that concerns us here."" I would argue that this pattern continues to this day, and even before Newton, this pattern was the case. We are just realizing more accepted theories, so it doesn't feel as ""wild"" as it did during Newton's time. For example, dimensional theory, dinosaurs, gravity, life, what's in a blackhole, what's at the center of the sun, earthquakes, the center of the earth, states of matter, and endless other questions are still full of competing theories and questions that are acceptable to have competing theories on. Paradigm acceptance does happen, just look at the idea dinosaurs have feathers, that was a fairly recent 2011 discovery. Accepted theories do get disrupted in a major way as well, just look at the field of economics introducing behavioral economics. Now you can't study economics very far without talking about behavioral economics.},
}
