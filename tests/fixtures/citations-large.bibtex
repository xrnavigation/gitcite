title = {Special Education Costs Are Rising, But Money From State and Feds Isn't},
year = {2018},
author = {Maya Srikrishnan},
publisher = {Voice of San Diego},
url = {https://www.voiceofsandiego.org/topics/education/skyrocketing-special-ed-costs-join-pensions-district-budget-busters/}
