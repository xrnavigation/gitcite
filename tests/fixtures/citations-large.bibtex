@misc{Biggs2024SystemsAndMethodsForInteractiveDigitalMaps,
title = {Patent No. {US}20240369372A1 - Systems and Methods for Interactive Digital Maps},
author = {Brandon Biggs},
year = {2024},
typeof = {Patent},
categories = {Digital, Map, Text, Interactive, Mine, patent},
abstract = {Methods and system for providing digital audio mapping are provided wherein data representing real or virtual worlds is obtained from internal or external data sources and used to generate a digital auditory map that can be navigated using auditory sound cues. The digital audio map can be created by a digital audio map generator and presented to the user through a digital audio map presentation interface. The digital audio map presentation interface can provide multiple navigation modes to the user, including a tree-based mode, a grid-based mode, and a first-person-based mode. The user is able to dynamically select the preferred navigation mode.},
url = {https://patents.google.com/patent/US20240369372A1/en},
}
@misc{ArchitectRegistrationExamination2025,
title = {Architect Registration Examination by the National Council of Architectural Registration Boards},
institution = {National Council of Architectural Registration Boards},
note = {Accessed April 11, 2025},
url = {https://www.ncarb.org/pass-the-are},
typeof = {Professional Publication},
categories = {Architect, Diagram, Exam, Test},
abstract = {The Architect Registration Examination® (ARE®) is a multi-division exam used to assess your knowledge and skills regarding the practice of architecture. The current version of the exam, ARE 5.0, is developed by NCARB and features six divisions. Completing ARE 5.0 by passing all six divisions is required by all U.S. jurisdictions as a key step on the path to earning a license.},
}
@misc{GeoJSONSpec2016,
title = {The {GeoJSON} Specification ({RFC} 7946)},
url = {https://geojson.org/},
year = {2016},
author = {{Working Group Geographic JSON (geojson)}},
typeof = {Specification},
categories = {Geojson, Map, Data, Spec},
abstract = {GeoJSON is a format for encoding a variety of geographic data structures. GeoJSON supports the following geometry types: Point, LineString, Polygon, MultiPoint, MultiLineString, and MultiPolygon. Geometric objects with additional properties are Feature objects. Sets of features are contained by FeatureCollection objects.},
}
