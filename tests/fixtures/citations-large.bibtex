@article{Weimer2017earlyTactileMaps,
abstract = {In Boston at what is now the Perkins School for the Blind, Samuel Gridley Howe produced two atlases during the 1830s with raised lines and alphabetic characters for blind students that were also legible for sighted readers. Believing that blind students needed to learn both the form and content of textbooks for the sighted, Howe chose materials and methods of production to mitigate difficulties that these design principles presented for blind users. Howe's commitment to visual forms of communication manifests a tension in nineteenth-century approaches to educating the blind between a belief in universal capabilities and one in sense-specific knowledge. [ABSTRACT FROM AUTHOR]},
author = {Weimer, David},
ISSN = {00840416},
journal = {Winterthur Portfolio},
keywords = {Tactile maps, Blind students, Perkins School for the Blind (Watertown, Mass.), Maps for people with visual disabilities, Howe, S. G. (Samuel Gridley), 1801-1876, Comstock, J. L., Comstock, J. L.. [illustration] Eclipse of the Moon, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Map of Greece, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Map of Greece: Explanation, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Map of Iceland, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Map of New Hampshire, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Map of Pennsylvania, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] New Hampshire: Explanation, Howe, S. G. (Samuel Gridley), 1801-1876. [illustration] Vermont},
number = {2/3},
pages = {135--158},
title = {To Touch a Sighted World: Tactile Maps in the Early Nineteenth Century.},
volume = {51},
url = {https://www.journals.uchicago.edu/doi/full/10.1086/694538},
year = {2017},
doi = {10.1086/694538}
}
@inproceedings{holloway2018accessible,
title = {Accessible Maps for the Blind: Comparing 3D Printed Models with Tactile Graphics},
author = {Holloway, Leona and Marriott, Kim and Butler, Matthew},
booktitle = {Proceedings of the 2018 CHI Conference on Human Factors in Computing Systems},
pages = {198},
year = {2018},
organization = {ACM},
abstract = {Tactile maps are widely used in Orientation and Mobility (O&M) training for people with blindness and severe vision impairment. Commodity 3D printers now offer an alternative way to present accessible graphics, however it is unclear if 3D models offer advantages over tactile equivalents for 2D graphics such as maps. In a controlled study with 16 touch readers, we found that 3D models were preferred, enabled the use of more easily understood icons, facilitated better short term recall and allowed relative height of map elements to be more easily understood. Analysis of hand movements revealed the use of novel strategies for systematic scanning of the 3D model and gaining an overview of the map. Finally, we explored how 3D printed maps can be augmented with interactive audio labels, replacing less practical braille labels. Our findings suggest that 3D printed maps do indeed offer advantages for O&M training.},
categories = {Tactile, Auditory, 3D, Map, Blind},
typeof = {Journal Artical}
}
