@article{kenny2012sport,
title = {Sport, scales, or war? Metaphors speech-language pathologists use to describe caseload management},
author = {Kenny, Belinda and Lincoln, Michelle},
journal = {International journal of speech-language pathology},
volume = {14},
number = {3},
pages = {247--259},
year = {2012},
publisher = {Taylor \& Francis},
url = {https://www.tandfonline.com/doi/full/10.3109/17549507.2012.651747},
categories = {Sped, Caseload, Overwork, SLP},
abstract = {Professionals’ experiences, perceptions, and attitudes may be reflected in the metaphors they use to describe and discuss important professional issues. This qualitative study explored speech-language pathologists’ experiences of caseload management through metaphorical analysis. Metaphors provided a lens for reflecting participants’ lived experiences and professional knowledge construction. Data was obtained from 16 practising speech-language pathologists during individual work place interviews. Participants included new graduate and experienced speech-language pathologists who were employed in hospital and community settings. Metaphors for caseload management were identified from participants’ transcribed narratives, then coded and organized into themes. Participants produced a total of 297 metaphors during professional practice narratives. Thematic analysis indicated that participants used three salient metaphors of sport, measuring scales, and war when they addressed caseload issues. Metaphors of sport, scales, and war reflected speech-language pathologists’ concerns about managing clients efficiently, perceived caseload burdens, and the conflict they experienced when resources were inadequate. These metaphors may also represent a continuum in speech-language pathologists’ personal and professional responses to caseload demands. Shared metaphors may contribute to the professional socialization of individuals entering a profession and to changing or maintaining workplace culture. Hence, speech-language pathologists need to consider the impact of using metaphors of sport, measuring scales, and war during interactions with clients and colleagues.},
typeof = {Journal Article},
Annotation = {This article provides both a fantastic lit review of workload for SLPs, talks about lower quality services for students when SLPs are over-worked, and how administrators are not in touch with the workload of the SLPs. "resources for caseload management have remained static (Druck & Ross, 2002; Grech, 2002; Hopper, Cleary, Donnelly, & Dalton, 2007; Kent-Walsh, Stark, & Binger, 2008; O'Donoghue & Dean-Claytor, 2008). This mismatch between expectations, demand, and resources may create tensions between philosophies of care and work place practices for speech-language pathologists." "surveys of practising health professionals have identified caseload management issues as barriers to evidence-based practice (Jette, Bacon, Batty, Carlson, Ferland, Hemingway, et al., 2003; Metcalfe, Lewin, Wisher, Perry, Bannigan, & Moffett, 2001)." "speech-language pathologists may perceive limited opportunities to access and apply current research when they have long waiting lists, large caseloads, and inadequate time or resources (Metcalfe et al., 2001; Vallino-Napoli & Reilly, 2004; Zipoli & Kennedy, 2005)." "professional burn out. Indeed, speech-language pathologists have reported the perceived need to provide compromised clinical care as a major contributor to workload stress and reduced job satisfaction (McLaughlin, Lincoln, & Adamson, 2008)." "“I hear a client's name dropped. I know I saw them but I have no idea what I saw them for”" "participants perceived healthcare administrators who “dictated” (9E) staffing levels were impervious to caseload challenges" "participants reported increasing referral rates were not matched by increased staffing levels." "Inevitably, clients judged as low priority on the basis of age, diagnosis, or prognosis were denied services. Participants typically discussed types of clients who were “seen” or “not seen” for therapy. Disturbingly, referral policies resulted in sub-groups within a community whose needs went unmet; a finding supporting McLeod, Press, and Phelan's (2010) concerns that children with communication disorders are not consistently identified and supported by healthcare providers." "When clients’ and carers’ individual needs are not included in decision-making processes, they may become isolated and disempowered healthcare consumers." "Cirrin et al.'s (2003) and Dowden et al.'s (2006) assertions that onerous caseloads restrict speech-language pathologists’ service delivery options." "Metaphors of burden, fatigue, and disillusionment confirm that caseload stresses may impact upon retention of new graduate and experienced speech-language pathologists (Edgar & Rosa-Lugo, 2007; Harris et al., 2009; McLaughlin et al., 2008)."},
doi = {10.3109/17549507.2012.651747}
}
@article{hegarty2021qualitative,
title = {A qualitative exploration of speech-language pathologists’ intervention and intensity provision for children with phonological impairment},
author = {Hegarty, Natalie and Titterington, Jill and Taggart, Laurence},
journal = {International Journal of Speech-Language Pathology},
volume = {23},
number = {2},
pages = {213--224},
year = {2021},
publisher = {Taylor \& Francis},
abstract = {Purpose The aim of this study was to explore the reasons behind speech-language pathologists’ (SLPs’) current clinical practices (intervention and intensity provision) for children (0–18 years) with phonological impairment. Method Three focus groups each with five SLPs and six 1:1 interviews with SLP managers from one region of the UK (n = 21) were carried out. A thematic analysis was undertaken. Result SLPs often used an eclectic mix of familiar approaches with easily-accessible therapy materials. SLPs only reported deviating from their core approach if the child did not progress in therapy. Mixed responses were gathered on the perceived feasibility of transferring evidence-based intervention intensities into clinical practice. The importance of parents to increase intensity provision at home was noted. Barriers to SLPs’ evidence-based decision-making included: time; confidence levels; service-related restrictions and; difficulty replicating research in practice. Having peer support and access to decision-making pathways and manualised intervention protocols were considered ways to overcome these barriers. Conclusion There is a research-practice gap in which SLPs’ current practices are driven by organisational factors, their own preferences and child-specific factors. To narrow this gap, SLPs suggested the development of time-saving, evidence-based tools.},
url = {https://www.tandfonline.com/doi/full/10.1080/17549507.2020.1769728},
categories = {SLP, Best-Practice, Intervention},
typeof = {Journal Article},
annotation = {This article investigated how SLPs performed and evaluated their own practice. The results showed hesitancy among SLPs to try new practices and the perception of new practices not being robust. SLPs also expressed difficulty measuring intervention intensity at home, which made it an impractical solution. SLPs also expressed the desire to have indirect time to do professional development and learn new interventions. SLPs also expressed it is difficult to be efficient with their time, their use of time may not be the best. They also said it would be ideal to perform miniature evidence-based case studies or smaller group studies within their own practice to contribute to the literature. One difficulty expressed was that seeing children is better than the quality of the session, and this attitude needs to change.},
doi = {10.1080/17549507.2020.1769728}
}
@article{hari2019overloaded,
title = {Overloaded With Tasks? Show Them the Numbers: Looking to advocate that all your responsibilities, both direct and indirect, contribute to workload? Try using ASHA’s new workload calculator—or one of several others—to show how you spend your time.},
author = {Hari Prasad, Aruna},
year = {2019},
publisher = {ASHA},
typeof = {Journal Article},
abstract = {Looking to advocate that all your responsibilities, both direct and indirect, contribute to workload? Try using ASHA’s new workload calculator—or one of several others—to show how you spend your time.},
categories = {Workload, SLP, Calculator},
url = {https://leader.pubs.asha.org/doi/full/10.1044/leader.FTR2.24082019.56},
annotations = {This calculator was validated with four case studies and no quantitative analysis. It provides a view of a week with graphs that show distribution of different tasks that are performed during the week. It is meant to show both direct and indirect time. The tool is meant to be used in conversations with other SLPs, staff, supervisors, special education directors, and administrators. There is also a fantastic list of other workload calculators and sites workload literature.},
doi = {10.1044/leader.ftr2.24082019.56}
}
@article{schwemm2018weighing,
title = {Weighing the Workload Options},
author = {Schwemm, Kerri},
year = {2018},
publisher = {ASHA},
abstract = {An SLP helped create a weighted workload system to ensure necessary staffing levels among the 100-plus SLPs in her education agency.},
typeof = {Journal Article},
categories = {Workload, SLP},
url = {https://leader.pubs.asha.org/doi/10.1044/leader.SCM.23072018.34},
annotation = {This describes a workload calculator that was developed by eight SLPs and a sped director for an agency. The only validation that was mentioned was by the authors on their caseloads. To help justify the calculator, the author explained: "Administrators making decisions about SLP assignments didn’t understand our scope of practice and weren’t aware of paperwork responsibilities." They also described the importance of the SLP's "role and contributions to student academic achievement." The workload calculator was developed in an Excel spreadsheet. This workload is meant to be done a minimum of three times a year, but the calculator can be filled out more frequently. The provider needs to fill out the workload sheet. The results of this calculator helps justify staffing, and more frequent the workload is filled out, more immediate workload relief can be provided. "the opportunity to adjust my caseload midway through the school year resulted in improved service delivery to students. I completed screenings and evaluations more quickly and thoroughly, increased collaborative consultative support with teachers, and was confident that my schedule permitted the time allocated on IEPs to meet student needs."},
doi = {10.1044/leader.scm.23072018.34}
}
@article{katakowski2020shift,
title = {Shift to workload model shows enhanced learning, reduced referrals},
author = {Katakowski, Diane and Frank, Mallory},
journal = {Leader Live},
year = {2020},
publisher = {ASHA},
abstract = {Using advocacy, data, and an evidence-based program, SLPs see increased student success after convincing their district to move from a caseload to a workload model.},
categories = {Workload, SLP},
typeof = {Journal Article},
url = {https://leader.pubs.asha.org/do/10.1044/leader.SCM.25082020.36/full/?utm_source = TrendMD&utm_medium = cpc&utm_campaign = The_ASHA_Leader_TrendMD_1},
annotation = {The data used to justify this transition to workload was showing how indirect time with non IEP students can prevent IEP referrals. The evaluation looked at a kindergarten classroom that completed a screening evaluation before the study, and again after 10 weeks, at the end of the study for both the experimental group and control group. "Results of the pilot showed 72% of kindergarten students met narrative language benchmarks after 10 weeks of SLP co-teaching. In non-pilot classrooms, fewer than 40% of students met the first benchmark. Students below this winter benchmark participated in the SLP-led small groups. Of these students, 47% met the narrative language benchmark by spring. We validated these language gains using the district’s writing formative assessment. Embedding SLPs in the early literacy system of support raised the oral language skills of most students and averted 10 to 29 kindergarten referrals to special education. IEP numbers for each SLP decreased by one to five students; each SLP was also serving seven to 10 more non-IEP students. Overall workload hours per week have remained consistent, indicating that SLPs spend less time in IEP and report-writing activities but more time working with students (see graphs online). Once our district’s central administration saw these data, they implemented the workload model district-wide."},
doi = {10.1044/leader.scm.25082020.36}
}
@phdthesis{pringle2021workload,
title = {WORKLOAD MANAGEABILITY: EXPLORING THE PERCEPTIONS OF SCHOOL-BASED SPEECH-LANGUAGE PATHOLOGISTS},
author = {Pringle, Kerry McLaughlin},
year = {2021},
school = {Slippery Rock University},
abstract = {Legal reform measures and evidence-based referral processes significantly expanded speech-language pathologists’ scope of practice; however, contemporary research initiatives fail to directly address perceived challenges that arise as a result of workload inequities. Therefore, the purpose of this qualitative research study was to investigate speech-language pathologists’ perceptions of workload management within the public-school setting. The contents of this narrative systematically describe federal and state legislative actions pertaining to professional responsibilities and the conceptual frameworks that are often used to evaluate personal and job-related workload implications. A purposeful sampling approach allowed the co-investigator to assemble a team of eight school-based speech-language pathologists, currently employed in public-school districts located in Southwestern Pennsylvania, who met an explicit set of criteria relevant to the premise of the investigation. Participants were interviewed and data was analyzed utilizing descriptive coding followed by NVivo coding in order to identify major themes and patterns in regard to the following research questions: What workload responsibilities do school-based speech-language pathologists perceive as the most demanding? How do school-based speech-language pathologists describe the relationship between perceived workload demands and job performance? How do school-based speech-language pathologists view the impact of perceived workload demands on their body, mood, and/or behavior? Four major themes emerged from the data and indicate the following: SLPs have a clear understanding of the terms caseload and workload in regard to school-based speech and language support services; Workload obligations perceivably cause SLPs to encounter psychological and physical implications, including stress, anxiety, and frustration; Workload obligations perceivably impact SLPs’ ability to meaningfully provide therapeutic services; and the roles and responsibilities of school-based SLPs are perceivably misinterpreted and/or misunderstood by educational stakeholders, including administrators, teachers, and parents. Findings from this study may contribute to future professional development initiatives, caseload dissemination methods, and the growing body of literature related to the topic.},
annotation = {This dissertation did a qualitative study asking 8 SLPs their perceptions around their workload. The first chapter presents how the SLP profession has significantly changed over the years, and now includes a significant amount of work in addition to direct services: "In addition to primary occupational obligations, ASHA certified SLPs may also be expected to offer mentoring services, participate in professional development initiatives, and promote academic growth through the use of evidence-based pedagogical methods (Brandel, 2020)." The chapter then goes into how many states have no established caseload cap, and those with a cap have it set very high. Finally, the chapter goes into a framework of workload and how high workload can attribute to significant negative mental health. "Ewen et al. (2020), investigated influential factors impacting burnout rates in SLPs. A review of literature, using various online databases, revealed conclusive evidence citing a link between job satisfaction, job stress, and burnout. Specifically, high demands, limited support, and low rewards led to ­perceived feelings of stress and subsequent burnout." The results found SLPs felt unheard around workload, When asked about workload, participants explained how states had a defined number of students that could be on a caseload, but this method does not consider severity of services: "workload would be understanding that certain students on your caseload, dependent upon their needs, may take up more hours of your time based on the frequency of sessions that they are serviced." Participants described that workload has a direct impact on quality of student services: "If my workload wasn't high, then I would be able to provide more direct services to students or provide services more frequently. Similarly, I think that I would be able to, not that services aren't individualized, but I think that I would be able to provide even more individualized instruction if I didn't have a higher workload which I think would probably help students meet goals faster." "More than half of the interviewees agreed that it is often “difficult” to “keep up with” clerical expectations, including electronic/written correspondence, report documentation, data collection, and Medicaid billing." "I would definitely say progress report writing, data collection, and medical access take time away from direct therapy sessions. I know that we're taking data during therapy sessions as well, but we're also having to enter it in a way that we can, you know, keep it for years to come in case we would get audited and then also have it in an organized way so that we're able to do our progress report writing more efficiently. I definitely feel that data collection and paperwork tasks impact your ability to accurately service students." "According to ASHA, 59% of SLPs who manage caseloads of at least 50 students perceive workload obligations, such as paperwork, as unmanageable (“Challenges of Successful Recruitment,” n.d.)." "Physical and/or emotional factors, including job satisfaction, stress, burnout, and/or anxiety often arise as a result of limited supply (resources) and increased demand (occupational responsibilities) (Ewen et al., 2020). The following data are indicative of such theories and add relevance to documented assertions." "workload tasks “can be mentally upsetting” and “overwhelming” for others, including P4. In an effort to complete required tasks in a timely manner, including collaborative activities and paperwork, P4 further describes “feeling anxious” and occasionally experiences “increased stress levels” during the school year." Administrators also have difficulty understanding SLP workloads: "In the past, I have mentioned to the Director of Special Education that my caseload is getting high. As a result, my methods of evaluation and instruction were questioned. Administrators asked if students were being service properly or if any should be dismissed." "they don't know what we do, so they can't help. Sometimes they don't understand what we want because they don't know what we do." "the efficacy of intervention services is somewhat dependent upon the “leadership of the supervisor” (Salloukh, 2019)." Participants also described increased workload due to the 2020 pandemic.},
url = {https://harbor.klnpa.org/slipperyrock/islandora/object/SRA%3A802/datastream/PDF/download/citation.pdf},
typeof = {Dissertation},
categories = {SLP, Workload},
}
@article{pogrund2019determining,
title = {Determining Type and Amount of Service Delivery Time by Teachers of Students with Visual Impairments: Results of a National Validation Study of the VISSIT},
author = {Pogrund, Rona L and Darst, Shannon and Munro, Michael},
journal = {Journal of Visual Impairment \& Blindness},
volume = {113},
number = {2},
pages = {129--139},
year = {2019},
publisher = {SAGE Publications Sage CA: Los Angeles, CA},
abstract = {Introduction: This research followed the lead of an initial validation study and responded to the call from the state education agency–endorsed Service Intensity Subcommittee of the Texas Action Committee for the Education of Students with Visual Impairments to conduct a larger scale validation study on the Visual Impairment Scale of Service Intensity of Texas (VISSIT). Methods: The authors collected survey data from 77 respondents using a mixed-methods survey research design. These data were used to determine the VISSIT’s validity and reliability. Participants represented urban, suburban, and rural geographic regions across 20 U.S. states. Results: The results of the national study showed that the VISSIT has social validity, which was supported by both ease of use and acceptability of the tool. The VISSIT’s consequential and content validity were also supported by the data collected. The internal consistency reliability showed reliability for the VISSIT with a Cronbach’s alpha calculated as being .935. Based on the results presented here, in which the social, consequential, and content validity of the VISSIT have been confirmed, it can also be confidently asserted that the VISSIT is construct valid. Discussion: The findings of this national study indicate an overall positive response to the usability and understandability of the VISSIT. Participants used the tool to provide quantifiable documentation to identify accurate student need for service across all expanded core curriculum areas as well as to provide administrators and families with research-based data to justify service type and time. Implications for practitioners: Respondents in the national study saw the VISSIT as an effective way to take student evaluation data and convert those results into a measurable recommendation for service type and intensity. The VISSIT helps a teacher of students with visual impairments to document how much time is needed for both direct and collaborative consultation services, as appropriate for each individual student.},
categories = {Blindness, Service Intensity},
typeof = {Journal Article},
url = {https://journals.sagepub.com/doi/abs/10.1177/0145482X19845756},
doi = {10.1177/0145482x19845756}
}
