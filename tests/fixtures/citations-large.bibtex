@article{DigitalMapToolAccessibilityComparison2024Biggs,
title = {Digital Map Tool Accessibility Comparison},
author = {Brandon Biggs},
year = {2024},
journal = {{XR} Navigation},
url = {https://xrnavigation.io/digital-map-tool-accessibility-comparison/},
typeof = {Blog Post},
month = {August},
categories = {WCAG, Digital, Map, Accessibility, Mine},
abstract = {Understanding the accessibility of digital map tools is essential for creating inclusive and accessible maps on your app or website. This is a systematic comparison of the accessibility of top digital map tools. The evaluation is based on the 14 criteria outlined in this report (Opens a new tab). These criteria were taken from the Web Accessibility Guidelines (WCAG) (Opens a new tab). The WCAG is used to evaluate compliance for many digital accessibility laws around the world (Opens a new tab). The 14 criteria are a partial list of all the guidelines. They are elements that the authors of the report thought were particularly applicable to digital maps. Note that most governments only require WCAG AA compliance, and only 12/14 criteria are WCAG AA.}
}
@misc{DesignForEveryGamerRNIB,
title = {Design for every gamer - DFEG},
url = {https://www.rnib.org.uk/living-with-sight-loss/assistive-aids-and-technology/tv-audio-and-gaming/design-for-every-gamer/},
abstract = {Every year, around 100,000 people in the UK must come to terms with losing their sight. It is our fundamental belief that everyone should have the right to game, however they see. That’s why we launched ‘Design for every gamer’, our initiative to create a better gaming world for people with sight loss and a rallying cry to the industry to start making real change.},
institution = {Roial National Institute for the Blind},
categories = {Game, Design, Blind},
typeof = Website},
note = {Accessed February 12, 2025},
}
@misc{GameAccessibilityGuidelines2025,
