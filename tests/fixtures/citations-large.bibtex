@unpublished{TheBusinessCaseForDigitalAccessibility2019,
title = {The Business Case for Digital Accessibility},
author = {{W3C Web Accessibility Initiative}},
year = {2019},
url = {https://www.w3.org/WAI/business-case/},
abstract = {This article examines the rationale for organizations to address accessibility. It includes tangible and intangible benefits, and the risks of not addressing accessibility adequately. It explores how accessibility can: • Drive Innovation: Accessibility features in products and services often solve unanticipated problems. • Enhance Your Brand: Diversity and inclusion efforts so important to business success are accelerated with a clear, well-integrated accessibility commitment. • Extend Market Reach: The global market of people with disabilities is over 1 billion people with a spending power of more than $6 trillion. Accessibility often improves the online experience for all users. • Minimize Legal Risk: Many countries have laws requiring digital accessibility, and the issue is of increased legal concern.},
categories = {Business, Accessibility, Inclusive Design},
typeof = {Trade Publication},
}
