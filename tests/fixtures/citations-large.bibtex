@article{McCallMcPherson2024AccessibilityEssentialsForGIS,
title={Accessibility essentials for GIS and mapping},
author={McCall, Jessica AND McPherson, Krista},
year={2024},
url={https://www.esri.com/arcgis-blog/products/instant-apps/mapping/accessibility-essentials-for-gis-and-mapping},
journal={ArcGIS Blog},
abstract={The information and data conveyed in GIS maps and apps should be accessible to everyone. Implementing digital accessibility in GIS and mapping helps reduce barriers to people with disabilities and ensures the widespread availability of information. However, digital accessibility in GIS and mapping can pose several challenges due to the inherently visual nature of the data.},
