@inproceedings{guerreiro2017virtual,
title = {Virtual navigation for blind people: Building sequential representations of the real-world},
author = {Guerreiro, Jo{\~a}o and Ahmetovic, Dragan and Kitani, Kris M and Asakawa, Chieko},
booktitle = {Proceedings of the 19th International ACM SIGACCESS Conference on computers and accessibility},
pages = {280--289},
year = {2017},
categories = {Digital, Auditory, XR, Map, Blind, Study},
abstract = {When preparing to visit new locations, sighted people often look at maps to build an a priori mental representation of the environment as a sequence of step-by-step actions and points of interest (POIs), e.g., turn right after the coffee shop. Based on this observation, we would like to understand if building the same type of sequential representation, prior to navigating in a new location, is helpful for people with visual impairments (VI). In particular, our goal is to understand how the simultaneous interplay between turn-by-turn navigation instructions and the relevant POIs in the route can aid the creation of a memorable sequential representation of the world. To this end, we present two smartphone-based virtual navigation interfaces: VirtualLeap, which allows the user to jump through a sequence of street intersection labels, turn-by-turn instructions and POIs along the route; and VirtualWalk, which simulates variable speed step-by-step walking using audio effects, whilst conveying similar route information. In a user study with 14 VI participants, most were able to create and maintain an accurate mental representation of both the sequential structure of the route and the approximate locations of the POIs. While both virtual navigation modalities resulted in similar spatial understanding, results suggests that each method is useful in different interaction contexts.},
typeof = {Journal Article},
url = {https://www.researchgate.net/publication/318913336_Virtual_Navigation_for_Blind_People_Building_Sequential_Representations_of_the_Real-World},
annotation = {They built two modes of navigation, one jumping from POI to POI, and the other using the accelerometer and gyroscope to control a walking character. The interface kept users on the road, and didn't seem to represent curved information. It also didn't represent polygonal representations, and the data was extremely simplified down to 5 blocks, six intersections, and 5 POIs. Regardless, users very much liked the interface and were able to walk the route with understanding where POIs were and when to turn on a route. They had trouble estimating distance though.},
doi = {10.1016/j.ijhcs.2019.102369}
}
@misc{AccessibilityOfGoogleMapsAPI,
title = {Issue 69541792: Accessibility of Google Maps {API}},
institution = {Google},
year = {2021},
url = {https://issuetracker.google.com/issues/69541792},
abstract = {We are attempting to build a map visualization using Google Maps Javascript API that follows the guidance of Web Content Accessibility Guidelines 2.0.  We are using the google.maps.Marker class to create a list of points that contain a few pieces of information. We want people who use screen readers to be able to have the tooltip information associated with the marker read out via synthesized speech. We also want people who rely on the keyboard to be able to navigate between various map markers and view the associated tooltip. The problems that we experience with the current HTML output rendered from the API calls are: Keyboard Access - WCAG 2.1.1: The individual Marker points do not receive keyboard focus when a user presses the tab key. Because the arrow keys are already used in the Map for panning and zooming, Google Maps API should render a keyboard accessible method for a user to move between individual markers on the map. Note that on the Google Maps website this has been done via an associated data list that receives keyboard focus and causes the marker information to be displayed, but this functionality is unavailable via the javascript API. Visual Keyboard Indication - WCAG 2.4.7: Because there is no way to get keyboard focus to the individual marker points on the map, there is also no visual indication of keyboard focus for those marker points. Name, Role, Value - WCAG 4.1.2: The screen reader will need the map marker to supply programmatic access information. We recommend that the tooltips displayed adhere to the ARIA Authoring Practices tooltip spec.},
categories = {Bug, Inaccessible, Google, Map, API},
typeof = {API},
}
