@article{Stuckey2018TactileLiteracy,
title = {Tactile Literacy},
author = {Amanda Stuckey},
year = {2018},
journal = {Printing History},
volume = {24},
url = {https://www.questia.com/library/journal/1G1-557578951/tactile-literacy},
abstract = {In an 1833 essay entitled "Education of the Blind," published in the North American Review, Samuel Gridley Howe made a call for what seemed impossible: a library of books printed specifically for sight-impaired readers. In particular, he calls for improvement upon the models of embossed print that had been circulating, unchanged in his view, in European schools for the blind for almost fifty years. (1) Even a single copy of the Bible, he urges, would be a "treasure" to a sight-impaired reader, serving as "the companion of every solitary moment" that had the power to "illuminate the dark night of his existence." (2) At the time of Howe's writing, the young reformer had been appointed superintendent of the New England Institution for the Education of the Blind (the Institution was only four years old in 1833, and today is the Perkins School for the Blind in Watertown, Massachusetts) and had traveled to schools in France, England, and Scotland to study pedagogical models for educating the blind. Yet only one book for the blind had been embossed in the United States, and Howe envisioned a much more extensive and accessible library for the sight-impaired students of his institution and beyond. (3) His call for a library was also a call for a new technology of book making in the United States. This call generated almost a century of experimentation with tactile print technologies on the part of individual printers, schools for the blind, and, eventually, an embossed-print publishing house. After all, as Howe predicted in the 1833 essay, "it is a beautiful and most valuable invention, which enables the blind 'to look/Along the pages of a book'."},
categories = {Tactile, Blind, Braille, History},
typeof = {Journal Article}
}
