@misc{Groves2023UnderstandingTheCostOfNotBeingAccessible,
title = {Understanding the cost of not being accessible},
author = {Karl Groves},
year = {2023},
abstract = {I’ve been writing on this site for a long time. In that time, I’ve written over a dozen times on the accessibility business case. Time and again, the message I’ve hoped to convey is that issue prevention is the best way to save money. Once lawyers become involved, all roads lead to one destination – and it is an expensive one. But avoiding issues is only possible on new work. So while it is fine for myself and others to talk about cost savings through avoiding issues, the truth is, the only organizations that avoid accessibility issues are those that have mature accessibility programs.},
url = {https://karlgroves.com/understanding-the-cost-of-not-being-accessible/},
categories = {Accessibility, Design, Inclusion},
typeof = {Blog Post},
annotation = {Justifies why building inclusive is the most cost effective strategy.},
}
@article{Katsnelson2023BlindResearchers,
title = {These tools help visually impaired scientists read data and journals},
author = {Alla Katsnelson},
url = {https://doi.org/10.1038/d41586-023-00645-6},
year = {2023},
abstract = {Innovative software and modes of presentation are helping to broaden access to the literature.},
categories = {Blind, Science, Accessibility, Diversity, Equity, Inclusion, Tools, Research},
annotation = {This article highlights the inequity BVIs face in science with less than 100 of the 52,124 of the researchers who applied for NIH funding in 2018 being blind. It highlights the difficulty BVIs have accessing papers, going to conferences, reviewing papers, and submitting papers. It discusses tools, such as screen readers, accessible PDFs, SciA11y, Olli, multimodal access and interactive data representation system (MAIDR), lithophanes, and Highcharts Sonification Studio. They also talk about the NIH commitment to diversity: <https://www.acd.od.nih.gov/documents/presentations/12092022_WGD_Disabilities_Subgroup_Report.pdf>.},
publisher = {nature},
typeof = {Journal Article},
doi = {10.1038/d41586-023-00645-6}
}
@misc{impactGeospatialServices2017,
title = {The economic impact of geospatial services},
year = {2017},
