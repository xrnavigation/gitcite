{
  "_comment": "Phase 1.A token matrix. The contrast-audit script verifies every (fg, bg) pair against its required ratio in BOTH themes on every CI run. AAA target: 7:1 for body text (1.4.6), 3:1 for non-text/UI (1.4.11), 3:1 for focus ring (2.4.13).",
  "themes": {
    "light": {
      "bg": "#ffffff",
      "bg-elevated": "#f4f4f5",
      "bg-sunken": "#e4e4e7",
      "fg": "#18181b",
      "fg-muted": "#3f3f46",
      "border": "#52525b",
      "accent": "#1e3a8a",
      "accent-fg": "#ffffff",
      "danger": "#991b1b",
      "danger-fg": "#ffffff",
      "success": "#14532d",
      "success-fg": "#ffffff",
      "warning": "#713f12",
      "warning-fg": "#ffffff",
      "focus-ring": "#1e40af"
    },
    "dark": {
      "bg": "#0a0a0b",
      "bg-elevated": "#18181b",
      "bg-sunken": "#050506",
      "fg": "#fafafa",
      "fg-muted": "#d4d4d8",
      "border": "#a1a1aa",
      "accent": "#bfdbfe",
      "accent-fg": "#0a0a0b",
      "danger": "#fecaca",
      "danger-fg": "#0a0a0b",
      "success": "#bbf7d0",
      "success-fg": "#0a0a0b",
      "warning": "#fde68a",
      "warning-fg": "#0a0a0b",
      "focus-ring": "#bfdbfe"
    }
  },
  "pairs": [
    { "fg": "fg", "bg": "bg", "min": 7.0, "label": "body text on bg" },
    { "fg": "fg", "bg": "bg-elevated", "min": 7.0, "label": "body text on bg-elevated" },
    { "fg": "fg-muted", "bg": "bg", "min": 7.0, "label": "muted text on bg" },
    { "fg": "fg-muted", "bg": "bg-elevated", "min": 7.0, "label": "muted text on bg-elevated" },
    { "fg": "accent-fg", "bg": "accent", "min": 7.0, "label": "accent button text" },
    { "fg": "danger-fg", "bg": "danger", "min": 7.0, "label": "danger button text" },
    { "fg": "success-fg", "bg": "success", "min": 7.0, "label": "success button text" },
    { "fg": "warning-fg", "bg": "warning", "min": 7.0, "label": "warning button text" },
    { "fg": "danger", "bg": "bg", "min": 7.0, "label": "inline danger text on bg" },
    { "fg": "success", "bg": "bg", "min": 7.0, "label": "inline success text on bg" },
    { "fg": "warning", "bg": "bg", "min": 7.0, "label": "inline warning text on bg" },
    { "fg": "border", "bg": "bg", "min": 3.0, "label": "border on bg (1.4.11)" },
    { "fg": "border", "bg": "bg-elevated", "min": 3.0, "label": "border on bg-elevated (1.4.11)" },
    { "fg": "focus-ring", "bg": "bg", "min": 3.0, "label": "focus ring on bg (2.4.13)" },
    { "fg": "focus-ring", "bg": "bg-elevated", "min": 3.0, "label": "focus ring on bg-elevated (2.4.13)" }
  ]
}
